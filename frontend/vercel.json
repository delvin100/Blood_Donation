{
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://ebloodbank.onrender.com/api/$1"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "https://ebloodbank.onrender.com/uploads/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/.*",
            "dest": "/index.html"
        }
    ]
}