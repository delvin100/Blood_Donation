{
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://ebloodbank.onrender.com/api/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://ebloodbank.onrender.com/uploads/:path*"
        },
        {
            "source": "/((?!api|uploads|assets|images|favicon).*)",
            "destination": "/index.html"
        }
    ]
}